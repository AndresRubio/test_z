# Copy to .env and adjust. All values shown are the defaults.
ZA_OLLAMA_BASE_URL=http://localhost:11434
ZA_CHAT_MODEL=gemma4:e4b
ZA_JUDGE_MODEL=gemma4:e2b
ZA_TOP_K=5
# Retrieval backend: bm25 (lexical only) or hybrid (BM25 + embeddings fused via
# RRF, ADR 0003). hybrid needs the optional extra: `uv sync --extra semantic`;
# if the embedding stack is missing it falls back to bm25 with a warning.
ZA_RETRIEVER_BACKEND=bm25
# SentenceTransformer model for the hybrid backend (downloaded on first use).
# Swap to e.g. sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 for
# cross-lingual retrieval.
ZA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RRF constant k: higher spreads rank credit deeper into each ranked list.
ZA_RRF_K=60
# Cosine floor for the semantic leg — the analog of BM25's score > 0 cutoff.
ZA_MIN_SEMANTIC_SIMILARITY=0.25
ZA_CONTEXT_CHARS_PER_PRODUCT=600
ZA_LLM_TIMEOUT_SECONDS=60
ZA_TEMPERATURE=0.2

# Ollama call tuning — trade-offs explained in the TO_EXPLAIN note in app/core/config.py.
# ZA_NUM_THREAD=8            # inference CPU threads; leave unset to let Ollama auto-detect
ZA_NUM_CTX=4096              # context window in tokens; bigger fits more cards/history, costs RAM + latency
ZA_TOP_P=0.9                 # nucleus-sampling cutoff for generation
ZA_KEEP_ALIVE=30m            # keep models loaded between calls — avoids multi-second cold reloads
                             # NOTE: keep_alive only helps if the Ollama server can hold Judge AND
                             # Generator at once. If `ollama ps` shows them evicting each other,
                             # every request pays two model swaps (live-measured ~3.4 s per swap);
                             # check the Ollama server's memory budget / OLLAMA_MAX_LOADED_MODELS.
# ZA_JUDGE_NUM_PREDICT=256  # Judge token cap. Leave UNSET for gemma4:e2b: it is a
                             # reasoning model, the cap counts thinking tokens too, and a
                             # starved trace returns empty content — fail-open then lets
                             # every query through (see TO_EXPLAIN in app/core/config.py).

ZA_CATALOG_PATH=product_catalog_dataset.json
ZA_MAX_PLAUSIBLE_PRICE=500.0
ZA_TRACING_ENABLED=false
ZA_PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
ZA_PHOENIX_PROJECT_NAME=assistant
