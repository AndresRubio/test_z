# Copy to .env and adjust. All values shown are the defaults.
ZA_OLLAMA_BASE_URL=http://localhost:11434
ZA_CHAT_MODEL=gemma4:e4b
ZA_JUDGE_MODEL=gemma4:e2b
ZA_TOP_K=5
ZA_CONTEXT_CHARS_PER_PRODUCT=600
ZA_LLM_TIMEOUT_SECONDS=60
ZA_TEMPERATURE=0.2

# Ollama call tuning — trade-offs explained in the TO_EXPLAIN note in app/core/config.py.
# ZA_NUM_THREAD=8            # inference CPU threads; leave unset to let Ollama auto-detect
ZA_NUM_CTX=4096              # context window in tokens; bigger fits more cards/history, costs RAM + latency
ZA_TOP_P=0.9                 # nucleus-sampling cutoff for generation
ZA_KEEP_ALIVE=30m            # keep models loaded between calls — avoids multi-second cold reloads
ZA_JUDGE_NUM_PREDICT=16      # token cap for the Judge's tiny JSON verdict — stops generation early

ZA_CATALOG_PATH=product_catalog_dataset.json
ZA_MAX_PLAUSIBLE_PRICE=500.0
ZA_TRACING_ENABLED=false
ZA_PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
ZA_PHOENIX_PROJECT_NAME=assistant
