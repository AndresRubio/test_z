# Copy to .env and adjust. All values shown are the defaults.

ZA_OLLAMA_BASE_URL=http://localhost:11434   # where Ollama is listening
ZA_CHAT_MODEL=gemma4:e4b                     # generates the answer
ZA_JUDGE_MODEL=gemma4:e2b                    # tiny model, on/off-topic check
ZA_TOP_K=5                                   # how many Variants retrieval returns

# Retrieval backend: bm25 (lexical) or hybrid (BM25 + embeddings via RRF, ADR 0003).
# hybrid needs `uv sync --extra semantic`; if missing, falls back to bm25 with a warning.
ZA_RETRIEVER_BACKEND=bm25
ZA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # hybrid only; swap to a multilingual model for cross-lingual
ZA_RRF_K=60                                  # hybrid: higher spreads rank credit deeper
ZA_MIN_SEMANTIC_SIMILARITY=0.25              # hybrid: cosine floor (like BM25's score > 0)

ZA_CONTEXT_CHARS_PER_PRODUCT=600             # chars of each Variant given to the generator
ZA_GREETING_STREAM_DELAY_SECONDS=0.035       # per-word delay so streamed greetings type out
ZA_LLM_TIMEOUT_SECONDS=60                    # per Ollama call
ZA_TEMPERATURE=0.2                           # generation randomness (lower = steadier)

# Ollama call tuning — full trade-offs in the TO_EXPLAIN note in app/core/config.py.
# ZA_NUM_THREAD=8            # inference CPU threads; unset = Ollama auto-detects
ZA_NUM_CTX=4096              # context window in tokens; bigger = more history, more RAM/latency
ZA_TOP_P=0.9                # nucleus-sampling cutoff
ZA_KEEP_ALIVE=30m           # keep models loaded; only helps if Ollama holds Judge AND Generator at once
# ZA_JUDGE_NUM_PREDICT=256  # leave UNSET: gemma4:e2b is a reasoning model, a cap starves its
                            # trace to empty, and fail-open then lets every query through

ZA_CATALOG_PATH=product_catalog_dataset.json # dataset ingested at startup
ZA_MAX_PLAUSIBLE_PRICE=500.0                 # Variants above this are quarantined
ZA_TRACING_ENABLED=false                     # Phoenix/OpenTelemetry tracing
ZA_PHOENIX_ENDPOINT=http://localhost:6006/v1/traces   # trace collector
ZA_PHOENIX_PROJECT_NAME=assistant                     # trace project name
